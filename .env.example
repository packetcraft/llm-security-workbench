# AIRS credentials
# Copy this file to .env and fill in your values
# .env is gitignored — never commit the real file

AIRS_API_KEY=your-x-pan-token-here
AIRS_PROFILE=your-profile-name-here

# AIRS Model Security — separate credentials from runtime AIRS_API_KEY
# Required for the 🔍 Model Security scanner in dev/8b (npm run model-scan)
# MODEL_SECURITY_CLIENT_ID=your-client-id-here
# MODEL_SECURITY_CLIENT_SECRET=your-client-secret-here
# TSG_ID=your-tenant-service-group-id-here
# SECURITY_GROUP_UUID_HF=your-hf-security-group-uuid-here
# MODEL_SECURITY_API_ENDPOINT=https://api.sase.paloaltonetworks.com/aims

# HuggingFace offline mode (LLM-Guard sidecar)
# Enable after running `npm run llmguard:warmup` to pre-download all models.
# Prevents any outbound calls to huggingface.co — required when running behind
# a VPN or corporate proxy that blocks or intercepts huggingface.co:443.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
