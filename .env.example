# AIRS credentials
# Copy this file to .env and fill in your values
# .env is gitignored — never commit the real file

AIRS_API_KEY=your-x-pan-token-here
AIRS_PROFILE=your-profile-name-here

# HuggingFace offline mode (LLM-Guard sidecar)
# Enable after running `npm run llmguard:warmup` to pre-download all models.
# Prevents any outbound calls to huggingface.co — required when running behind
# a VPN or corporate proxy that blocks or intercepts huggingface.co:443.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1
